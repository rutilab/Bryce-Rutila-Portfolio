# Optional: Neon Postgres connection string for first-party analytics (https://neon.tech)
# DATABASE_URL=

# Admin dashboard at /admin — required for sign-in (use long random values in production)
# ADMIN_SECRET must be at least 16 characters
# ADMIN_SECRET=
# ADMIN_PASSWORD=

# Optional: salt for hashing visitor IPs in analytics (falls back to ADMIN_SECRET if unset)
# ANALYTICS_IP_SALT=

          <h4 className="text-lg font-semibold text-white mb-2">{title}</h4>
          <p className="text-base text-white/80 mb-2">{description}</p>
          <p className="text-sm text-white/50">Design Requirement: {requirement}</p>
        </div>
      </div>
    </div>
  );
}

